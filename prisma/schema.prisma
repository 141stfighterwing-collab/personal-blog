// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Role enum for user permissions
enum Role {
  ADMIN
  REVIEWER
  USER
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // In production, this should be hashed with bcrypt
  email     String?  @unique
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  posts     BlogPost[]
  pages     Page[]
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  content     String   // Markdown content
  excerpt     String?  // Short description
  slug        String   @unique
  videoUrl    String?  // YouTube, Vimeo, TikTok URL for embedded videos
  published   Boolean  @default(false)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([published])
  @@index([createdAt])
}

model ExternalLink {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  category    String   // "blog", "news", "github", "other"
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model NewsItem {
  id        String   @id @default(cuid())
  headline  String
  url       String?
  category  String   @default("general") // "ai", "geopolitics", "cybersecurity", "general"
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([category])
}

// Page Block types for layered content creation
enum BlockType {
  HERO         // Full-width banner with title
  TEXT         // Rich text paragraph
  IMAGE        // Single image with caption
  GALLERY      // Multiple images grid
  VIDEO        // Video embed
  QUOTE        // Blockquote
  DIVIDER      // Horizontal rule
  COLUMNS      // Multi-column layout
  SIDEBAR      // Sidebar content
  CTA          // Call to action button
  CODE         // Code block
  EMBED        // Custom embed (iframe)
}

model Page {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String?     // Meta description for SEO
  bannerUrl   String?     // Hero/banner image URL
  bannerAlt   String?     // Alt text for banner
  showSidebar Boolean     @default(true)
  sidebarMenu String?     // JSON array of menu items
  published   Boolean     @default(false)
  authorId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  author      User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  blocks      PageBlock[]

  @@index([published])
  @@index([slug])
}

model PageBlock {
  id        String   @id @default(cuid())
  pageId    String
  blockType BlockType
  content   String   // JSON content specific to block type
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([sortOrder])
}
